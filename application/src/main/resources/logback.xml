<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="versionKey"
                    converterClass="org.example.logger.VersionConverter" />

    <property scope="context" name="logversion" value="v1.234" />
    <property scope="context" resource='configuration.properties'/>
    <property scope="context" resource='build-info.tmp'/>

    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
-        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>
                %-5level %d{HH:mm:ss.SSS} adela %logger{36} %versionKey - %message%n%throwable
            </Pattern>
        </layout>
    </appender>

<!--    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">-->
