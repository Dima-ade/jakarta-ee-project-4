<!--                <timestampFormatTimezoneId>Etc/UTC</timestampFormatTimezoneId>-->
<!--                <message>message</message>-->
<!--                <logger>logger</logger>-->
<!--                <level>level</level>-->
<!--            </providers>-->
<!--        </encoder>-->
<!--    </appender>-->

    <!-- LOG everything at INFO level -->
